#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
CLI="$ROOT/dist/cli.js"

if [ ! -f "$CLI" ]; then
  echo "ap: missing build — run: npm run build" >&2
  exit 1
fi

exec node "$CLI" "$@"
