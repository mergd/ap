{
  "name": "@mergd/ap",
  "version": "0.1.0",
  "description": "Agent-portable local secrets — bundles, doctor, ap run",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mergd/ap.git"
  },
  "homepage": "https://github.com/mergd/ap#readme",
  "bugs": {
    "url": "https://github.com/mergd/ap/issues"
  },
  "bin": {
    "ap": "bin/ap"
  },
  "files": [
    "bin",
    "dist",
    "schema",
    ".cursor/skills/ap"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\"",
    "dev": "node --import tsx src/main.ts",
    "test": "node --import tsx --test test/*.ts",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run check"
  },
  "dependencies": {
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
